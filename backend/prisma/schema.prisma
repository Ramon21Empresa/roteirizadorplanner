// Prisma Schema — RoutePlan
// Suporta PostgreSQL (produção) e SQLite (desenvolvimento local)
// Para trocar: altere o provider abaixo e o DATABASE_URL no .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Troque para "sqlite" se não tiver PostgreSQL disponível
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// VENDEDOR — representa o representante comercial
// A residência/base é o ponto de início e fim de cada rota
// ─────────────────────────────────────────
model Vendedor {
  id        String   @id @default(uuid())
  codigo    String   @unique    // Código interno (ex: V01)
  nome      String
  endereco  String
  lat       Float?              // Coordenada da base do vendedor
  lng       Float?
  ativo     Boolean  @default(true)
  cor       String?             // Cor para exibição no mapa (hex)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientes    Cliente[]
  rotas       Rota[]
  planejamentos PlanejamentoDia[]
}

// ─────────────────────────────────────────
// CLIENTE — ponto de visita na rota
// ─────────────────────────────────────────
model Cliente {
  id         String   @id @default(uuid())
  codigo     String   @unique    // Código único de negócio (ex: C001)
  nome       String
  endereco   String
  lat        Float?              // Preenchido pela geocodificação
  lng        Float?
  ativo      Boolean  @default(true)
  observacao String?

  // Vínculo com vendedor (pode ser nulo — cliente sem vendedor)
  vendedorId String?
  vendedor   Vendedor? @relation(fields: [vendedorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rotaClientes   RotaCliente[]
  planejamentos  PlanejamentoDia[]
}

// ─────────────────────────────────────────
// ROTA — uma rota salva/simulada
// ─────────────────────────────────────────
model Rota {
  id          String   @id @default(uuid())
  nome        String                    // Nome descritivo
  vendedorId  String
  vendedor    Vendedor @relation(fields: [vendedorId], references: [id])
  kmTotal     Float    @default(0)      // KM calculado (Haversine ou Directions API)
  tempoMin    Int      @default(0)      // Tempo estimado em minutos
  otimizada   Boolean  @default(false)  // true = gerada pelo algoritmo TSP
  status      RotaStatus @default(RASCUNHO)
  observacao  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientes RotaCliente[]
}

enum RotaStatus {
  RASCUNHO    // Em montagem
  SIMULADA    // Calculada mas não confirmada
  CONFIRMADA  // Aprovada para execução
}

// ─────────────────────────────────────────
// ROTA_CLIENTE — ordem dos clientes dentro da rota
// Tabela pivot com campo de ordenação
// ─────────────────────────────────────────
model RotaCliente {
  id        String  @id @default(uuid())
  rotaId    String
  rota      Rota    @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id])
  ordem     Int                         // Posição na sequência da rota
  distProx  Float?                      // KM até o próximo ponto

  @@unique([rotaId, clienteId])         // Um cliente só aparece uma vez por rota
  @@unique([rotaId, ordem])             // Ordem única dentro da rota
}

// ─────────────────────────────────────────
// PLANEJAMENTO_DIA — alocação de cliente em dia/semana
// Representa o calendário logístico (drag-and-drop)
// ─────────────────────────────────────────
model PlanejamentoDia {
  id          String   @id @default(uuid())
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  vendedorId  String
  vendedor    Vendedor @relation(fields: [vendedorId], references: [id])
  diaSemana   DiaSemana
  semanasMes  Int                        // 1, 2, 3 ou 4
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Um cliente não pode ter dois registros no mesmo dia/semana
  @@unique([clienteId, diaSemana, semanasMes])
}

enum DiaSemana {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
}
